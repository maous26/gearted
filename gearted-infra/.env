# Environnement
NODE_ENV=development
PORT=3000

# Base de données
DB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=gearted

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=86400

# AWS S3
AWS_ACCESS_KEY=your_aws_access_key_here
AWS_SECRET_KEY=your_aws_secret_key_here
AWS_S3_BUCKET=gearted-images
AWS_REGION=eu-north-1

# Firebase
FIREBASE_API_KEY=votre_cle_api
FIREBASE_AUTH_DOMAIN=votre_domaine.firebaseapp.com
FIREBASE_PROJECT_ID=votre_projet_id
FIREBASE_STORAGE_BUCKET=votre_bucket.appspot.com
FIREBASE_MESSAGING_SENDER_ID=votre_sender_id
FIREBASE_APP_ID=votre_app_id
