# API Configuration
API_URL=http://localhost:3000/api

# Firebase Configuration
FIREBASE_API_KEY=your_api_key
FIREBASE_APP_ID=your_app_id
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_storage_bucket
FIREBASE_AUTH_DOMAIN=your_auth_domain

# OAuth Configuration
# Replace with actual Google Web Client ID from Google Cloud Console
GOOGLE_WEB_CLIENT_ID=your_google_web_client_id_here

# Replace with actual Facebook App ID from Facebook Developer Console
FACEBOOK_APP_ID=your_facebook_app_id_here

# Features Flags
ENABLE_AR_FEATURES=false

# ================================================================
# IMPORTANT: OAUTH CONFIGURATION INSTRUCTIONS
# ================================================================
# 
# 1. GOOGLE OAUTH:
#    - Go to https://console.cloud.google.com/
#    - Create a new project or use an existing one
#    - Enable the Google+ API
#    - Create OAuth credentials (Web client)
#    - Copy the Client ID to GOOGLE_WEB_CLIENT_ID
#
# 2. FACEBOOK OAUTH:
#    - Go to https://developers.facebook.com/
#    - Create a new app or use an existing one
#    - Add Facebook Login product
#    - Set up OAuth redirect URIs
#    - Copy the App ID to FACEBOOK_APP_ID
#
# For more details, see: /Users/moussa/gearted/OAUTH_SETUP_GUIDE.md
