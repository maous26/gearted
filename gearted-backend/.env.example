# Environnement
NODE_ENV=development
PORT=3000

# Base de données
DB_URI=mongodb://localhost:27017/gearted

# JWT
JWT_SECRET=votre_secret_jwt
JWT_EXPIRATION=86400

# AWS S3
AWS_ACCESS_KEY=votre_cle_acces
AWS_SECRET_KEY=votre_cle_secrete
AWS_S3_BUCKET=gearted-images
AWS_REGION=eu-west-3

# Firebase
FIREBASE_API_KEY=votre_cle_api
FIREBASE_AUTH_DOMAIN=votre_domaine.firebaseapp.com
FIREBASE_PROJECT_ID=votre_projet_id
FIREBASE_STORAGE_BUCKET=votre_bucket.appspot.com
FIREBASE_MESSAGING_SENDER_ID=votre_sender_id
FIREBASE_APP_ID=votre_app_id
